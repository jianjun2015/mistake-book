/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.btn-primary[disabled] {
  background: #a0cfff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.btn-default {
  background: #fff;
  color: #333;
  border-radius: 8rpx;
  border: 1rpx solid #d9d9d9;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.tag-math { background: #fff1f0; color: #ff4d4f; }
.tag-physics { background: #e6f7ff; color: #1890ff; }
.tag-chemistry { background: #f6ffed; color: #52c41a; }
.tag-biology { background: #f9f0ff; color: #722ed1; }
.tag-english { background: #fff7e6; color: #faad14; }
.tag-chinese { background: #fff0f6; color: #eb2f96; }

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-0 { background: #fff1f0; color: #ff4d4f; }
.status-1 { background: #fff7e6; color: #faad14; }
.status-2 { background: #f6ffed; color: #52c41a; }

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
