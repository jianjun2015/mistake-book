/* pages/search/search.wxss */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fff;
}

.search-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
}

.result-header {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.mistake-item {
  margin-bottom: 16rpx;
}

.mistake-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.mistake-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 4rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.mistake-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.welcome {
  text-align: center;
  padding: 100rpx 0;
}

.welcome-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.welcome-text {
  font-size: 28rpx;
  color: #999;
}
